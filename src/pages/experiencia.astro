---
/**
 * @archivo    experiencia.astro
 * @modulo     Página Experiencia
 * @descripcion Cuatro pilares experienciales con imágenes alternadas grandes,
 *              estilo editorial, scroll-triggered.
 * @version    1.0.0
 */

import Layout from '../layouts/Layout.astro';
import Marquee from '../components/Marquee.astro';
import { pilares } from '../data/contenido';
import { ambiente, vintage, platos } from '../data/imagenes';

// Imagen por pilar — alternancia visual
const imagenesPilares = [
  ambiente.salon,        // 01 El salón
  ambiente.horno,        // 02 La pizza al molde
  ambiente.mostrador,    // 03 La barra al paso
  ambiente.cocina,       // 04 El mostrador y la mesa
];
---

<Layout
  titulo="Experiencia · Pin Pun"
  descripcion="Cuatro elementos hacen a Pin Pun: el salón de azulejos, la pizza al molde, la barra al paso y la atención de mozos que conocen la mesa."
>

  {/* ── PORTADA ──────────────────────────────────────────────────── */}
  <section class="exp-hero">
    <div class="container exp-hero__inner">
      <p class="eyebrow reveal">La experiencia</p>
      <h1 class="exp-hero__title" data-split>
        No venís solo a comer. Entrás en una escena.
      </h1>
      <p class="exp-hero__sub reveal">
        Pin Pun es un viaje a la Buenos Aires de mediados del siglo XX, conservada en azulejos, carteles luminosos y horno de piedra encendido. Cuatro elementos sostienen esa escena.
      </p>
    </div>

    <div class="exp-hero__hero-img" data-clip data-parallax="0.1">
      <img src={ambiente.exterior} alt="Frente de Pin Pun en Av. Corrientes" loading="eager" />
    </div>
  </section>

  {/* ── PILARES ──────────────────────────────────────────────────── */}
  {pilares.map((pilar, idx) => (
    <section class="pilar section" data-tema={idx % 2 === 0 ? 'claro' : 'oscuro'}>
      <div class="container pilar__grid" data-orden={idx % 2}>
        <div class="pilar__media" data-clip>
          <img src={imagenesPilares[idx]} alt={`${pilar.titulo} · Pin Pun`} loading="lazy" />
        </div>

        <div class="pilar__copy">
          <span class="pilar__num">{pilar.numero}</span>
          <h2 class="pilar__t" data-split>{pilar.titulo}</h2>
          <p class="pilar__p reveal">{pilar.bajada}</p>
        </div>
      </div>
    </section>
  ))}

  <Marquee />

  {/* ── DETALLES SECUNDARIOS ─────────────────────────────────────── */}
  <section class="section detalles">
    <div class="container">
      <header class="detalles__head">
        <p class="eyebrow reveal">Detalles</p>
        <h2 class="detalles__t" data-split>
          Cosas chicas que hacen Pin Pun.
        </h2>
      </header>

      <ul class="detalles__lista">
        <li class="detalle reveal">
          <span class="detalle__icono">✦</span>
          <h3>Sin cubierto</h3>
          <p>Nunca lo cobramos. Tampoco mínimo de consumo. Vení a tomar una porción y un vaso de agua si querés.</p>
        </li>
        <li class="detalle reveal">
          <span class="detalle__icono">✦</span>
          <h3>Mostrador al paso</h3>
          <p>Una porción de muzzarella, una de fugazzeta, una copa de vermut. De pie, en cinco minutos, sin reservar.</p>
        </li>
        <li class="detalle reveal">
          <span class="detalle__icono">✦</span>
          <h3>Para llevar</h3>
          <p>Toda la carta sale en cajas. Pizzas medianas, grandes y por porciones individuales.</p>
        </li>
        <li class="detalle reveal">
          <span class="detalle__icono">✦</span>
          <h3>Pet-friendly en vereda</h3>
          <p>Las mesas de afuera reciben perros tranquilos. Hay agua si te olvidás la suya.</p>
        </li>
        <li class="detalle reveal">
          <span class="detalle__icono">✦</span>
          <h3>Eventos y mesas grandes</h3>
          <p>Para cumpleaños, despedidas o festejos: avisanos con un día de anticipación y reservamos sector.</p>
        </li>
        <li class="detalle reveal">
          <span class="detalle__icono">✦</span>
          <h3>Vermut hour</h3>
          <p>De 18:00 a 20:00, vermut con sifón a precio de fábrica. La hora dorada de los habitués.</p>
        </li>
      </ul>
    </div>
  </section>

  {/* ── CITA DE CIERRE ───────────────────────────────────────────── */}
  <section class="section cita">
    <div class="container">
      <blockquote class="cita__bloque reveal">
        <p class="cita__texto" data-split>
          “El que entra a Pin Pun por primera vez ya sabe que va a volver.<br/>
          El secreto está en la masa, los azulejos y el tiempo.”
        </p>
        <footer class="cita__autor">— Reseña de un cliente, hace 30 años</footer>
      </blockquote>
    </div>
  </section>

</Layout>

<style>
  /* ── PORTADA ─────────────────────────────────────────────────────── */
  .exp-hero {
    padding-top: 8rem;
    padding-bottom: var(--space-2xl);
  }

  .exp-hero__inner {
    max-width: 70ch;
    margin-bottom: var(--space-xl);
  }

  .exp-hero__title {
    font-size: var(--fs-2xl);
    font-style: italic;
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.03em;
    margin-block: 1.4rem 1.8rem;
  }

  .exp-hero__sub {
    font-size: var(--fs-md);
    color: var(--color-text-soft);
    line-height: 1.6;
    max-width: 55ch;
  }

  .exp-hero__hero-img {
    aspect-ratio: 21 / 9;
    overflow: hidden;
    margin-inline: var(--gutter);
    border-radius: var(--radius-lg);
  }

  .exp-hero__hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── PILAR ──────────────────────────────────────────────────────── */
  .pilar {
    padding-block: var(--space-2xl);
  }

  .pilar[data-tema="oscuro"] {
    background-color: var(--color-carbon);
    color: var(--color-crema);
  }

  .pilar__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .pilar__grid { grid-template-columns: 1fr 1fr; gap: var(--space-2xl); }
    .pilar__grid[data-orden="1"] .pilar__media { order: 2; }
  }

  .pilar__media {
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .pilar__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pilar__num {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 5rem);
    font-style: italic;
    font-weight: 300;
    color: var(--color-tomate);
    line-height: 1;
    display: block;
    margin-bottom: 1rem;
  }

  .pilar__t {
    font-size: var(--fs-2xl);
    font-style: italic;
    font-weight: 300;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .pilar[data-tema="oscuro"] .pilar__t { color: var(--color-crema); }

  .pilar__p {
    font-size: var(--fs-md);
    color: var(--color-text-soft);
    line-height: 1.7;
    font-weight: 300;
    max-width: 50ch;
  }

  .pilar[data-tema="oscuro"] .pilar__p {
    color: rgba(245, 239, 230, 0.75);
  }

  /* ── DETALLES ───────────────────────────────────────────────────── */
  .detalles__head {
    text-align: center;
    margin-bottom: var(--space-xl);
    max-width: 50ch;
    margin-inline: auto;
  }

  .detalles__t {
    font-size: var(--fs-2xl);
    font-style: italic;
    font-weight: 300;
    line-height: 1.05;
    margin-top: 1rem;
  }

  .detalles__lista {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .detalles__lista { grid-template-columns: repeat(3, 1fr); gap: 3rem 2.5rem; }
  }

  .detalle {
    text-align: left;
  }

  .detalle__icono {
    color: var(--color-tomate);
    font-size: 1.4rem;
    display: block;
    margin-bottom: 0.6rem;
  }

  .detalle h3 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-style: italic;
    font-weight: 400;
    margin-bottom: 0.6rem;
  }

  .detalle p {
    color: var(--color-text-soft);
    line-height: 1.6;
    font-size: var(--fs-base);
  }

  /* ── CITA ───────────────────────────────────────────────────────── */
  .cita {
    background-color: var(--color-crema-soft);
    text-align: center;
  }

  .cita__bloque { max-width: 60ch; margin-inline: auto; }

  .cita__texto {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    font-style: italic;
    font-weight: 300;
    line-height: 1.3;
    color: var(--color-text);
    quotes: none;
  }

  .cita__autor {
    margin-top: 1.5rem;
    font-size: var(--fs-sm);
    letter-spacing: 0.05em;
    color: var(--color-text-mute);
  }
</style>
