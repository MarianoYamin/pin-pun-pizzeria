---
/**
 * @archivo    resenas.astro
 * @modulo     Página Reseñas
 * @descripcion Reconocimientos de prensa, premio Muza 5K y citas de clientes.
 * @version    1.0.0
 */

import Layout from '../layouts/Layout.astro';
import Marquee from '../components/Marquee.astro';
import { prensa, testimonios } from '../data/contenido';
import { ambiente } from '../data/imagenes';
---

<Layout
  titulo="Reseñas y prensa · Pin Pun"
  descripcion="Pin Pun ganó el Muza 5K 2015 a la mejor pizza de mozzarella. Recomendada por Turismo Buenos Aires, La Nación y la guía La Mejor Pizzería."
>

  {/* ── PORTADA ──────────────────────────────────────────────────── */}
  <section class="res-hero">
    <div class="container res-hero__inner">
      <p class="eyebrow reveal">Reseñas y prensa</p>
      <h1 class="res-hero__title" data-split>
        Lo que dijeron del salón en estos cien años.
      </h1>
      <p class="res-hero__sub reveal">
        Premios, menciones, vecinos. Lo que se escribe sobre Pin Pun se sostiene en lo mismo: la masa, la atención y los azulejos.
      </p>
    </div>
  </section>

  {/* ── PREMIO DESTACADO ─────────────────────────────────────────── */}
  <section class="section premio theme-dark">
    <div class="container premio__inner">
      <div class="premio__copy">
        <p class="premio__pre">2015 · Buenos Aires</p>
        <h2 class="premio__t" data-split>
          Ganadora del Muza 5K.
        </h2>
        <p class="premio__p reveal">
          El Muza 5K es el maratón porteño que premia a la mejor pizza de mozzarella de la ciudad. En 2015, Pin Pun se llevó el reconocimiento a casi noventa años de su fundación. Lo que el barrio sabía hace décadas, la ciudad lo confirmó con un trofeo.
        </p>
        <p class="premio__p reveal">
          La receta premiada es la misma que sigue saliendo del horno hoy: medio kilo de mozzarella entera, masa fermentada veinticuatro horas, pincelada de salsa San Marzano.
        </p>
      </div>

      <div class="premio__medalla reveal">
        <span class="premio__anio script">2015</span>
        <span class="premio__txt">Muza<br/>5K</span>
        <span class="premio__sub">Mejor pizza<br/>de mozzarella</span>
      </div>
    </div>
  </section>

  {/* ── MENCIONES PRENSA ─────────────────────────────────────────── */}
  <section class="section prensa-grid">
    <div class="container">
      <header class="prensa-grid__head">
        <p class="eyebrow reveal">Prensa</p>
        <h2 class="prensa-grid__t" data-split>
          Recomendada en guías y diarios.
        </h2>
      </header>

      <ul class="prensa-grid__lista">
        {prensa.map((p) => (
          <li class="prensa-grid__item reveal">
            <span class="prensa-grid__medio">{p.medio}</span>
            <p class="prensa-grid__nota">{p.nota}</p>
            {p.enlace && p.enlace !== '#' && (
              <a href={p.enlace} target="_blank" rel="noopener noreferrer" class="prensa-grid__link" data-cursor>
                Leer la nota →
              </a>
            )}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <Marquee />

  {/* ── TESTIMONIOS ──────────────────────────────────────────────── */}
  <section class="section testimonios">
    <div class="container">
      <header class="testimonios__head">
        <p class="eyebrow reveal">Vecinos y visitantes</p>
        <h2 class="testimonios__t" data-split>
          Lo que dicen los que vuelven cada semana.
        </h2>
      </header>

      <ul class="testimonios__lista">
        {testimonios.map((t) => (
          <li class="testimonio reveal">
            <span class="testimonio__comilla">”</span>
            <blockquote class="testimonio__cita">{t.cita}</blockquote>
            <footer class="testimonio__autor">
              <strong>{t.autor}</strong>
              <span>{t.contexto}</span>
            </footer>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* ── ESTADÍSTICAS ─────────────────────────────────────────────── */}
  <section class="section stats">
    <div class="container">
      <ul class="stats__lista">
        <li class="stats__item reveal">
          <span class="stats__num">31.000+</span>
          <span class="stats__label">Reseñas en plataformas</span>
        </li>
        <li class="stats__item reveal">
          <span class="stats__num">4.2 / 5</span>
          <span class="stats__label">Puntaje promedio</span>
        </li>
        <li class="stats__item reveal">
          <span class="stats__num">1.585</span>
          <span class="stats__label">Votos en La Mejor Pizzería</span>
        </li>
        <li class="stats__item reveal">
          <span class="stats__num">98</span>
          <span class="stats__label">Años de tradición</span>
        </li>
      </ul>
    </div>
  </section>

  {/* ── CTA FINAL ────────────────────────────────────────────────── */}
  <section class="section res-cta">
    <div class="container res-cta__inner">
      <h2 class="res-cta__t" data-split>
        La próxima reseña la podés escribir vos.
      </h2>
      <p class="res-cta__p reveal">
        Vení, comé, y contanos.
      </p>
      <div class="res-cta__actions reveal">
        <a href="/contacto" class="btn btn--primary" data-magnetic>Cómo llegar</a>
        <a href="/carta" class="btn btn--ghost" data-magnetic>Ver la carta</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ── PORTADA ─────────────────────────────────────────────────────── */
  .res-hero {
    padding: 9rem 0 var(--space-xl);
  }

  .res-hero__inner { max-width: 65ch; }

  .res-hero__title {
    font-size: var(--fs-2xl);
    font-style: italic;
    font-weight: 300;
    line-height: 1;
    letter-spacing: -0.03em;
    margin-block: 1.4rem;
  }

  .res-hero__sub {
    font-size: var(--fs-md);
    color: var(--color-text-soft);
    line-height: 1.6;
    max-width: 55ch;
  }

  /* ── PREMIO ─────────────────────────────────────────────────────── */
  .premio {
    background-color: var(--color-carbon);
    color: var(--color-crema);
  }

  .premio__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .premio__inner { grid-template-columns: 1.4fr 1fr; gap: var(--space-2xl); }
  }

  .premio__pre {
    font-size: var(--fs-xs);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-dorado);
    margin-bottom: 1rem;
  }

  .premio__t {
    font-size: var(--fs-2xl);
    font-style: italic;
    font-weight: 300;
    line-height: 1.05;
    color: var(--color-crema);
    margin-bottom: 1.5rem;
  }

  .premio__p {
    color: rgba(245, 239, 230, 0.75);
    font-size: var(--fs-md);
    line-height: 1.7;
    font-weight: 300;
    max-width: 55ch;
  }

  .premio__p + .premio__p { margin-top: 1.2rem; }

  .premio__medalla {
    aspect-ratio: 1;
    max-width: 380px;
    margin-inline: auto;
    border: 2px solid var(--color-dorado);
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 2rem;
    text-align: center;
    color: var(--color-dorado);
    position: relative;
    transition: transform var(--t-med) var(--ease-out);
  }

  .premio__medalla:hover {
    transform: rotate(-4deg) scale(1.03);
  }

  .premio__medalla::before {
    content: '';
    position: absolute;
    inset: 12px;
    border: 1px solid rgba(201, 168, 124, 0.4);
    border-radius: 50%;
  }

  .premio__anio {
    font-size: 2.4rem;
    font-style: italic;
    margin-bottom: 0.5rem;
  }

  .premio__txt {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 3rem);
    font-weight: 500;
    line-height: 1;
    color: var(--color-crema);
    margin-block: 0.5rem 0.8rem;
  }

  .premio__sub {
    font-size: var(--fs-xs);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    line-height: 1.5;
  }

  /* ── PRENSA ─────────────────────────────────────────────────────── */
  .prensa-grid__head {
    margin-bottom: var(--space-xl);
    max-width: 55ch;
  }

  .prensa-grid__t {
    font-size: var(--fs-2xl);
    font-style: italic;
    font-weight: 300;
    line-height: 1.05;
    margin-top: 1rem;
  }

  .prensa-grid__lista {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border-top: 1px solid var(--color-line);
  }

  @media (min-width: 768px) {
    .prensa-grid__lista { grid-template-columns: 1fr 1fr; }
  }

  .prensa-grid__item {
    padding: 2rem;
    border-bottom: 1px solid var(--color-line);
    transition: background-color var(--t-fast) var(--ease-out);
  }

  @media (min-width: 768px) {
    .prensa-grid__item:nth-child(odd) { border-right: 1px solid var(--color-line); }
  }

  .prensa-grid__item:hover {
    background-color: rgba(199, 62, 29, 0.04);
  }

  .prensa-grid__medio {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.6rem;
    color: var(--color-tomate);
    display: block;
    margin-bottom: 0.8rem;
  }

  .prensa-grid__nota {
    color: var(--color-text);
    font-size: var(--fs-base);
    line-height: 1.6;
    font-weight: 300;
  }

  .prensa-grid__link {
    display: inline-block;
    margin-top: 1rem;
    color: var(--color-tomate);
    font-size: var(--fs-sm);
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
  }

  /* ── TESTIMONIOS ────────────────────────────────────────────────── */
  .testimonios {
    background-color: var(--color-crema-soft);
  }

  .testimonios__head {
    margin-bottom: var(--space-xl);
    max-width: 55ch;
  }

  .testimonios__t {
    font-size: var(--fs-2xl);
    font-style: italic;
    font-weight: 300;
    line-height: 1.05;
    margin-top: 1rem;
  }

  .testimonios__lista {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .testimonios__lista { grid-template-columns: repeat(3, 1fr); }
  }

  .testimonio {
    background-color: var(--color-crema);
    padding: 2.5rem 2rem;
    border-radius: var(--radius-lg);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .testimonio__comilla {
    font-family: var(--font-display);
    font-size: 5rem;
    line-height: 0.7;
    color: var(--color-tomate);
    font-style: italic;
  }

  .testimonio__cita {
    font-size: var(--fs-md);
    color: var(--color-text);
    line-height: 1.55;
    font-weight: 300;
    flex: 1;
  }

  .testimonio__autor {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-line);
    font-size: var(--fs-sm);
    color: var(--color-text-soft);
  }

  .testimonio__autor strong {
    color: var(--color-text);
    font-weight: 500;
  }

  /* ── STATS ──────────────────────────────────────────────────────── */
  .stats__lista {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    .stats__lista { grid-template-columns: repeat(4, 1fr); }
  }

  .stats__item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 2rem 1rem;
  }

  .stats__num {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-style: italic;
    font-weight: 300;
    color: var(--color-tomate);
    line-height: 1;
  }

  .stats__label {
    font-size: var(--fs-sm);
    color: var(--color-text-soft);
    letter-spacing: 0.05em;
  }

  /* ── CTA ────────────────────────────────────────────────────────── */
  .res-cta {
    text-align: center;
  }

  .res-cta__inner { max-width: 50ch; margin-inline: auto; }

  .res-cta__t {
    font-size: var(--fs-2xl);
    font-style: italic;
    font-weight: 300;
    line-height: 1.05;
    margin-bottom: 1rem;
  }

  .res-cta__p {
    font-size: var(--fs-md);
    color: var(--color-text-soft);
    margin-bottom: 2rem;
  }

  .res-cta__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
